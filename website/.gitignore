# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# Yarn (this subproject's own root, since the repo root's `.yarn/*` rule
# is anchored to the repo root and does not cascade down into website/)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# the repo root's bare `lib/` rule (for the library's build output) also
# incidentally matches this subproject's own src/lib/ helper folder
!src/lib/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/
